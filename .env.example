# Either set account+bucket directly:
R2_ACCOUNT_ID=e123e4b567ef8f9dc7dc70bcbc5ce8b2
R2_BUCKET=bucketname

# Or provide the S3 API URL and let the deploy script infer account+bucket:
# R2_S3_API_URL=https://e123e4b567ef8f9dc7dc70bcbc5ce8b2.r2.cloudflarestorage.com/bucketname

R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# Cloudflare API bootstrap (bucket/domain/rules automation)
CF_API_TOKEN=your_cloudflare_api_token
CF_ZONE_ID=your_cloudflare_zone_id
# Optional if not using R2_ACCOUNT_ID above
# CF_ACCOUNT_ID=your_cloudflare_account_id

# Domain settings for bootstrap script
SITE_WWW_DOMAIN=www.example.com
# Optional: if set, script creates apex -> www redirect
# SITE_APEX_DOMAIN=example.com
